{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula-agents/agents/actions/spec/schema/contract.schema.json",
  "title": "Active Contract",
  "description": "Structural contract for agents/actions/spec/_contract.yaml. Names the active policy version and owns the shared values consumed by every action. validate_action_specs.py additionally enforces that active_version equals the newest published history bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": ["active_version", "history_dir", "shared"],
  "properties": {
    "active_version": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}(-r\\d+)?$"},
    "history_dir": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "shared": {"$ref": "#/$defs/shared"}
  },
  "$defs": {
    "shared": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_effective_date", "run_id_format", "base_run_files",
        "coverage_min_pct", "commands_log_schema", "context_preamble", "requirements"
      ],
      "properties": {
        "contract_effective_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "run_id_format": {"type": "string", "minLength": 1},
        "run_id_suffix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["argv"],
          "properties": {"argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
        },
        "run_id_forbidden": {"type": "array", "items": {"type": "string"}},
        "base_run_files": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "artifacts_subdirs": {"type": "array", "items": {"type": "string"}},
        "commands_log_schema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fields"],
          "properties": {"fields": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
        },
        "coverage_min_pct": {"type": "integer", "minimum": 0, "maximum": 100},
        "banned_words": {"type": "array", "items": {"type": "string"}},
        "context_preamble": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "requirements": {"$ref": "#/$defs/requirements"}
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "security_scans_required", "kg_reconciliation_required",
        "kg_generated_regen_required", "compile_projection_contract"
      ],
      "properties": {
        "security_scans_required": {"type": "boolean"},
        "required_security_scan_classes": {"type": "array", "items": {"type": "string"}},
        "kg_reconciliation_required": {"type": "boolean"},
        "kg_generated_regen_required": {"type": "boolean"},
        "compile_projection_contract": {"type": "boolean"}
      }
    }
  }
}
