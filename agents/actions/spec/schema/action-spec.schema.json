{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula-agents/agents/actions/spec/schema/action-spec.schema.json",
  "title": "Active Action Specification",
  "description": "Structural contract for an active action policy file (agents/actions/spec/<action>.yaml). Semantic invariants (placeholder allowlist, path containment, duplicate IDs, undeclared mutations, active-version tie) are enforced by validate_action_specs.py, not by this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "action_doc", "contract", "run_id", "inputs", "ownership", "gates", "stop_conditions"],
  "properties": {
    "action": {"type": "string", "pattern": "^[a-z][a-z-]*$"},
    "action_doc": {"type": "string", "minLength": 1},
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scope", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "scope": {"enum": ["feature-completion", "base-run-only", "read-only-audit", "merge"]},
        "version": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}(-r\\d+)?$"}
      }
    },
    "run_id": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "var"],
      "properties": {
        "scheme": {"enum": ["contract", "integrate"]},
        "var": {"type": "string", "minLength": 1}
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {"type": "array", "items": {"$ref": "#/$defs/input_field"}},
        "optional": {"type": "array", "items": {"$ref": "#/$defs/input_field"}}
      }
    },
    "auto_resolved": {"type": "object", "additionalProperties": {"type": "string"}},
    "retrieval": {"type": "object"},
    "context_load": {"type": "array", "items": {"type": "string"}},
    "ownership": {
      "type": "object",
      "additionalProperties": {"type": "array", "items": {"type": "string"}}
    },
    "gates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/gate"}},
    "severity_gate": {"enum": ["standard", "review-family", "none"]},
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["operator-friendly", "automation-safe"]},
      "description": "Prompt variants render-prompts.py generates for this action (default: both)."
    },
    "forbidden": {"type": "array", "items": {"type": "string"}},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "conflict_resolution": {"type": "array"},
    "notes": {"type": "object", "additionalProperties": {"type": "string"}}
  },
  "$defs": {
    "input_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "format": {"type": "string"},
        "enum": {"type": "array", "items": {"type": "string"}},
        "default": {"type": "string"},
        "required_when": {"type": "string"}
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "role"],
      "properties": {
        "id": {"type": "string", "pattern": "^G\\d+$"},
        "title": {"type": "string", "minLength": 1},
        "role": {"$ref": "#/$defs/role"},
        "role_switch": {"type": "string"},
        "artifacts": {"type": "array", "items": {"type": "string"}},
        "manifest_status_after": {"type": "string"},
        "operations": {"type": "array", "items": {"$ref": "#/$defs/operation"}},
        "constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "forbid": {"type": "string"},
              "reason": {"type": "string"}
            },
            "required": ["forbid", "reason"]
          }
        },
        "judgment": {"type": "string"}
      }
    },
    "role": {
      "enum": [
        "product-manager", "architect", "backend-developer", "frontend-developer",
        "ai-engineer", "quality-engineer", "devops", "code-reviewer",
        "security", "technical-writer", "blogger", "integrator"
      ]
    },
    "operation": {
      "type": "object",
      "description": "Exactly one typed operation. A bare string command is not an object and is therefore rejected: executable policy is typed data, never shell text.",
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["run"],
          "properties": {"run": {"$ref": "#/$defs/run_op"}}
        },
        {
          "additionalProperties": false,
          "required": ["checkpoint"],
          "properties": {"checkpoint": {"$ref": "#/$defs/checkpoint_op"}}
        },
        {
          "additionalProperties": false,
          "required": ["write"],
          "properties": {"write": {"$ref": "#/$defs/write_op"}}
        }
      ]
    },
    "run_op": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv", "cwd"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "cwd": {"enum": ["framework", "product"]},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "expected_artifacts": {"type": "array", "items": {"type": "string"}},
        "mutates": {"type": "array", "items": {"type": "string"}},
        "reason": {"type": "string"}
      }
    },
    "checkpoint_op": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "requires", "produces"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "requires": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "produces": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "write_op": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "after"],
      "properties": {
        "artifact": {"type": "string", "minLength": 1},
        "after": {"type": "string", "minLength": 1},
        "mutates": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
