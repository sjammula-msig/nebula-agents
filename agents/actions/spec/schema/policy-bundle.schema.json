{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula-agents/agents/actions/spec/schema/policy-bundle.schema.json",
  "title": "Historical Policy Bundle",
  "description": "Structural contract for an immutable, fully-resolved historical policy bundle (agents/actions/spec/history/<version>.yaml). A bundle carries every shared value and action matrix needed to interpret evidence produced under its version; it never inherits a mutable value from the active contract. validate_action_specs.py enforces monotonic versions, filename==version, and effective_from==version==shared.contract_effective_date.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "effective_from", "shared", "actions"],
  "properties": {
    "version": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}(-r\\d+)?$"},
    "effective_from": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "description": {"type": "string"},
    "shared": {"$ref": "#/$defs/shared"},
    "actions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/action_matrix"}
    }
  },
  "$defs": {
    "shared": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_effective_date", "run_id_format", "base_run_files",
        "coverage_min_pct", "commands_log_schema", "context_preamble", "requirements"
      ],
      "properties": {
        "contract_effective_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "run_id_format": {"type": "string", "minLength": 1},
        "run_id_suffix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["argv"],
          "properties": {"argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
        },
        "run_id_forbidden": {"type": "array", "items": {"type": "string"}},
        "base_run_files": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "artifacts_subdirs": {"type": "array", "items": {"type": "string"}},
        "commands_log_schema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fields"],
          "properties": {"fields": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
        },
        "coverage_min_pct": {"type": "integer", "minimum": 0, "maximum": 100},
        "banned_words": {"type": "array", "items": {"type": "string"}},
        "context_preamble": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "requirements": {"$ref": "#/$defs/requirements"}
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "security_scans_required", "kg_reconciliation_required",
        "kg_generated_regen_required", "compile_projection_contract"
      ],
      "properties": {
        "security_scans_required": {"type": "boolean"},
        "required_security_scan_classes": {"type": "array", "items": {"type": "string"}},
        "kg_reconciliation_required": {"type": "boolean"},
        "kg_generated_regen_required": {"type": "boolean"},
        "compile_projection_contract": {"type": "boolean"}
      }
    },
    "action_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "gates"],
      "properties": {
        "scope": {"enum": ["feature-completion", "base-run-only", "read-only-audit", "merge"]},
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "role", "required_artifacts"],
            "properties": {
              "id": {"type": "string", "pattern": "^G\\d+$"},
              "role": {"type": "string", "minLength": 1},
              "required_artifacts": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
