{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula-agents.local/schemas/f0001-launch-descriptor.schema.json",
  "title": "F0001 Native Provider Launch Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "provider_key",
    "executable_path",
    "argv",
    "cwd",
    "inherited_env_names",
    "owner_uid",
    "correlation_id",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[0-9a-f]{8}$"},
    "provider_key": {"type": "string", "enum": ["codex", "claude"]},
    "executable_path": {"type": "string", "minLength": 1},
    "argv": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"type": "string", "maxLength": 65536}
    },
    "cwd": {"type": "string", "minLength": 1},
    "inherited_env_names": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 32,
      "items": {"type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$", "maxLength": 80}
    },
    "owner_uid": {"type": "integer", "minimum": 0},
    "correlation_id": {"type": "string", "format": "uuid"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
