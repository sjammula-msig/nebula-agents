{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nebula-agents.local/schemas/f0001-runtime-event.schema.json",
  "title": "F0001 Runtime Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "sequence",
    "event_type",
    "occurred_at",
    "actor",
    "correlation_id",
    "payload"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[0-9a-f]{8}$"},
    "sequence": {"type": "integer", "minimum": 1},
    "event_type": {
      "type": "string",
      "enum": [
        "RuntimeDirectoryInitialized",
        "LaunchRequested",
        "RunLaunched",
        "LaunchFailed",
        "SessionAttached",
        "SessionMissing",
        "SessionRecovered",
        "SessionExited",
        "ArtifactObserved",
        "ArtifactUnavailable",
        "ValidatorStarted",
        "ValidatorCompleted",
        "ValidatorTimedOut",
        "ValidatorCancelled",
        "GateDecisionBlocked",
        "GateApproved",
        "GateHeld",
        "GateResumed",
        "TranscriptEnabled",
        "TranscriptCompleted",
        "TranscriptFailed",
        "RecoveryAttempted",
        "AuthorizationDenied",
        "StateRecoveryApplied"
      ]
    },
    "occurred_at": {"type": "string", "format": "date-time"},
    "actor": {"$ref": "#/$defs/actor"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "payload": {
      "type": "object",
      "maxProperties": 32,
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null", "array", "object"]
      }
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uid", "username", "role"],
      "properties": {
        "uid": {"type": "integer", "minimum": 0},
        "username": {"type": "string", "minLength": 1, "maxLength": 256},
        "role": {"type": "string", "enum": ["LocalOperator", "Reviewer", "System"]},
        "display_label": {"type": ["string", "null"], "maxLength": 80}
      }
    }
  }
}
